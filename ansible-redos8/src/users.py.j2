    critical_err = "[ИБ-КРАХ] Фатальная ошибка: Переменные SERVICE_DB_USER или SERVICE_DB_PASSWORD не заданы в .env!"
    print(critical_err)
    raise RuntimeError(critical_err)

# Автоматически собираем пуленепробиваемую строку DSN на лету!
