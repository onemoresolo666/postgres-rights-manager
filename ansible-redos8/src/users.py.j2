# # №6: ИЗОЛИРОВАННОЕ СОЗДАНИЕ УЗ ПАНЕЛИ ИБ (БЕЗ СМЕНЫ ПАРОЛЕЙ)
# =========================================================================
@router.post("/manage-postgres-users")
@router.post("/manage-postgres-users/")
def security_only_create_postgres_user(
    req: SecurityOnlyCreateRequest,
    current_user: str = Depends(RoleChecker(["Security_Manager"]))
):
    # ИБ-ЛОГ: Фиксируем попытку изолированного создания роли в режиме Zero Trust
    logger.info(
        f"[ИБ-АУДИТ] >>> ЗАПРОС ИЗОЛИРОВАННОГО СОЗДАНИЯ РОЛИ | "
        f"Офицер ИБ: '{current_user}' | Сервер: '{req.target_server}' | "
        f"Пользователь: '{req.db_user_name}' | Режим: '{req.action_mode}'"
    )

    # Жесткий Zero Trust заслон: если режим не CREATE_ONLY — немедленно рубим транзакцию
    if req.action_mode != "CREATE_ONLY":
        logger.warning(
            f"[ИБ-АУДИТ] !!! ОТКАЗ В ОПЕРАЦИИ | Недопустимый режим действия '{req.action_mode}' "
            f"от офицера '{current_user}'. Контур заблокирован в режиме CREATE_ONLY."
        )
        raise HTTPException(
            status_code=403,
            detail="ИБ Запрет: В данном контуре разрешено исключительно создание новых учетных записей!"
        )

    server_config = utils.get_server_from_db(req.target_server)
    # Гарантируем жесткий сброс сессии через 5 секунд, если хост недоступен
    server_config["connect_timeout"] = 5

    alphabet = string.ascii_letters + string.digits + "!@#$%^&*()_+-="
    generated_password = "".join(secrets.choice(alphabet) for _ in range(16))

    user_ident = sql.Identifier(req.db_user_name)
    pass_literal = sql.Literal(generated_password)

    check_query = "SELECT 1 FROM pg_roles WHERE rolname = %s"
    create_query = sql.SQL(
        "CREATE ROLE {user} WITH LOGIN PASSWORD {password} NOSUPERUSER NOCREATEDB NOCREATEROLE INHERIT;"
    ).format(user=user_ident, password=pass_literal)

    try:
        with connect(**server_config) as conn:
            conn.autocommit = True
            with conn.cursor() as cur:
                
                # -------------------------------------------------------------------------
                # ИБ-ЗАЩИТА: Локальный перехват ошибок СУБД для предотвращения дедлоков
                # -------------------------------------------------------------------------
                try:
                    # Намертво проверяем существование роли в кластере PostgreSQL
                    cur.execute(check_query, (req.db_user_name,))
                    is_role_exists = cur.fetchone()
                except Exception as check_err:
                    logger.error(f"[ИБ-ОТКАЗ] Не удалось проверить роль '{req.db_user_name}' на удаленной СУБД: {str(check_err)}")
                    raise HTTPException(status_code=422, detail=f"Ошибка СУБД при валидации роли: {str(check_err)}")

                if is_role_exists:
                    # МОНУМЕНТАЛЬНЫЙ ИБ-БЛОК: Если роль найдена — выкидываем жесткий отказ
                    logger.warning(
                        f"[ИБ-АУДИТ] !!! СРАБАТЫВАНИЕ ЗАЩИТЫ | Попытка перезаписи пароля существующей роли "
                        f"'{req.db_user_name}' на сервере '{req.target_server}' от офицера '{current_user}'."
                    )
                    raise HTTPException(
                        status_code=400,
                        detail=f"ИБ Запрет: Роль '{req.db_user_name}' уже существует в СУБД! Изменение её пароля в данном изолированном контуре заблокировано."
                    )

                # Если пользователя нет — выполняем чистый CREATE ROLE
                logger.info(f"[ИБ-АУДИТ] -> Роль '{req.db_user_name}' свободна. Выполняем изолированный CREATE ROLE.")
                try:
                    cur.execute(create_query)
                except Exception as create_err:
                    logger.error(f"[ИБ-ОТКАЗ] Не удалось создать роль '{req.db_user_name}': {str(create_err)}")
                    raise HTTPException(status_code=422, detail=f"Удаленная СУБД отклонила изолированное создание роли: {str(create_err)}")

        email_status = "success"
        email_err = None

        # Генерируем одноразовую ссылку доступа и шлем шифрованный лог на Email
        logger.info(f"[ИБ-АУДИТ] -> Инициируем генерацию секретного токена и отправку почты для '{req.db_user_name}'...")
        mail_success = send_credentials_email(
            req.employee_email, req.db_user_name, generated_password, server_config["host"], server_config["port"]
        )

        if not mail_success:
            email_status = "email_failed"
            email_err = "SMTP шлюз отклонил доставку или упала локальная БД панели"
            logger.warning(f"[ИБ-АУДИТ] !!! СБОЙ ДОСТАВКИ | Не удалось направить токен доступа для '{req.db_user_name}' на адрес '{req.employee_email}'")

        # Запечатываем операцию в сквозной журнал гибридного супер-аудита ИБ панели
        utils.log_operation(
            req.target_server, req.db_user_name, req.employee_email,
            "SECURITY_CREATE_USER", "LOGIN", email_status, email_err, admin_username=current_user
        )

        logger.info(f"[ИБ-АУДИТ] <<< ИЗОЛИРОВАННАЯ РОЛЬ УСПЕШНО СОЗДАНА | Администратор: '{current_user}'. Почта: {email_status.upper()}")
        return {"status": "success", "message": f"Новая роль '{req.db_user_name}' успешно создана! Доступы направлены на почту."}

    except HTTPException:
        raise
    except Exception as e:
        err_msg = str(e)
        utils.log_operation(
            req.target_server, req.db_user_name, req.employee_email,
            "SECURITY_CREATE_USER", "LOGIN", "error", err_msg, admin_username=current_user
        )

        # КРИТИЧНО ДЛЯ ИБ: Записываем фатальный сбой транзакции в логгер ОС с подробным traceback
        logger.error(f"[ИБ-КРАХ] Ошибка изолированного создания роли '{req.db_user_name}' офицером '{current_user}' на сервере '{req.target_server}': {err_msg}", exc_info=True)

        # Маскируем сырую ошибку PostgreSQL для защиты архитектуры корпоративной сети от утечек
        raise HTTPException(
            status_code=500,
            detail="Ошибка выполнения операции на удаленном сервере СУБД. Убедитесь в доступности узла и проверьте лимиты роли суперпользователя."
        )
