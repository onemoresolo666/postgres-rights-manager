# # 4. БЛОКИРОВКА / РАЗБЛОКИРОВКА УЧЕТНОЙ ЗАПИСИ
# =========================================================================
@router.post("/users/status")
@router.post("/users/status/")
def lock_user(
    req: LockUserRequest,
    current_user: str = Depends(RoleChecker(["admin", "Security_Manager"]))
):
    current_action = req.action.strip().upper()

    # ИБ-ЛОГ: Фиксируем попытку изменения статуса активности роли в удаленной СУБД
    logger.info(
        f"[ИБ-АУДИТ] >>> ЗАПРОС ИЗМЕНЕНИЯ СТАТУСА РОЛИ СУБД | "
        f"Администратор: '{current_user}' | Сервер: '{req.target_server}' | "
        f"Пользователь: '{req.username}' | Действие: {current_action}"
    )

    server_config = utils.get_server_from_db(req.target_server)
    # Гарантируем жесткий разрыв соединения через 5 секунд, если хост недоступен
    server_config["connect_timeout"] = 5 
    
    user_ident = sql.Identifier(req.username)
    check_query = "SELECT 1 FROM pg_roles WHERE rolname = %s"

    try:
        with connect(**server_config) as conn:
            conn.autocommit = True
            with conn.cursor() as cur:
                
                # 1. Локальный перехват проверки существования пользователя
                try:
                    cur.execute(check_query, (req.username,))
                    is_user_exists = cur.fetchone()
                except Exception as check_err:
                    logger.error(f"[ИБ-ОТКАЗ] Не удалось проверить роль '{req.username}' на удаленной СУБД: {str(check_err)}")
                    raise HTTPException(status_code=422, detail=f"Ошибка связи с СУБД при валидации роли: {str(check_err)}")

                if not is_user_exists:
                    logger.warning(f"[ИБ-АУДИТ] !!! ОБЪЕКТ НЕ НАЙДЕН | Пользователь '{req.username}' не существует на сервере '{req.target_server}'.")
                    raise HTTPException(status_code=404, detail=f"Пользователь '{req.username}' не найден на целевом сервере!")

                # 2. ИСПОЛНЕНИЕ ДЕЙСТВИЯ: LOCK (БЛОКИРОВКА РОЛИ)
                if current_action == "LOCK":
                    logger.info(f"[ИБ-АУДИТ] -> Накладываем ограничение NOLOGIN на роль '{req.username}'...")
                    
                    try:
                        cur.execute(sql.SQL("ALTER ROLE {user} NOLOGIN;").format(user=user_ident))
                    except Exception as lock_err:
                        logger.error(f"[ИБ-ОТКАЗ] СУБД отклонила команду NOLOGIN для '{req.username}': {str(lock_err)}")
                        raise HTTPException(status_code=422, detail=f"Удаленный сервер PostgreSQL отклонил блокировку: {str(lock_err)}")

                    utils.log_operation(
                        req.target_server, req.username, "LOGIN_PRIVILEGE", "LOCK_USER", "LOCK",
                        "success", admin_username=current_user
                    )

                    logger.info(f"[ИБ-АУДИТ] <<< УСПЕХ | Роль '{req.username}' успешно заблокирована администратором '{current_user}'.")
                    return {"status": "success", "message": f"Пользователь '{req.username}' успешно заблокирован!"}

                # 3. ИСПОЛНЕНИЕ ДЕЙСТВИЯ: UNLOCK (РАЗБЛОКИРОВКА РОЛИ)
                elif current_action == "UNLOCK":
                    logger.info(f"[ИБ-АУДИТ] -> Снимаем ограничение NOLOGIN (выдаем LOGIN) для роли '{req.username}'...")
                    
                    try:
                        cur.execute(sql.SQL("ALTER ROLE {user} LOGIN;").format(user=user_ident))
                    except Exception as unlock_err:
                        logger.error(f"[ИБ-ОТКАЗ] СУБД отклонила команду LOGIN для '{req.username}': {str(unlock_err)}")
                        raise HTTPException(status_code=422, detail=f"Удаленный сервер PostgreSQL отклонил разблокировку: {str(unlock_err)}")

                    utils.log_operation(
                        req.target_server, req.username, "LOGIN_PRIVILEGE", "LOCK_USER", "REVOKE_LOCK",
                        "success", admin_username=current_user
                    )

                    logger.info(f"[ИБ-АУДИТ] <<< УСПЕХ | Роль '{req.username}' успешно разблокирована администратором '{current_user}'.")
                    return {"status": "success", "message": f"Пользователь '{req.username}' успешно разблокирован!"}

                else:
                    logger.warning(f"[ИБ-АУДИТ] !!! КОРРУПТИВНЫЙ ЗАПРОС | Передано недопустимое действие '{current_action}' от '{current_user}'")
                    raise HTTPException(status_code=400, detail=f"Недопустимое действие: {req.action}")

    except HTTPException:
        raise
    except Exception as e:
        err_msg = str(e)
        bad_action = "LOCK_USER" if current_action == "LOCK" else "UNLOCK_USER"
        bad_priv = "LOCK" if current_action == "LOCK" else "UNLOCK"

        # Запись об ошибке во внутренний аудит-журнал СУБД панели
        utils.log_operation(
            req.target_server, req.username, "LOGIN_PRIVILEGE", bad_action, bad_priv,
            "error", err_msg, admin_username=current_user
        )

        # КРИТИЧНО ДЛЯ ИБ: Логируем фатальный сбой транзакции в логгер ОС с полной трассировкой
        logger.error(f"[ИБ-КРАХ] Не удалось изменить статус роли '{req.username}' администратором '{current_user}' на сервере '{req.target_server}': {err_msg}", exc_info=True)

        # Маскируем сырую ошибку PostgreSQL для защиты архитектуры корпоративной сети от утечек
        raise HTTPException(
            status_code=500,
            detail="Ошибка выполнения операции на удаленном сервере СУБД. Убедитесь в доступности узла и проверьте права роли."
        )

# =========================================================================
# # 5. API-РОУТЕР ОДНОРАЗОВОГО ПРОСМОТРА ПАРОЛЯ С ГАРАНТИРОВАННЫМ JSON-ОТВЕТОМ
# =========================================================================
@router.get("/view-password/{token_id}")
@router.get("/view-password/{token_id}/")
async def view_one_time_password(token_id: str):
    """Атомарно выдает пароль пользователю ОДИН раз и мгновенно сжигает токен в СУБД панели"""
    # ИБ-ЛОГ: Фиксируем сам факт обращения к конфиденциальному одноразовому токену
    logger.info(f"[ИБ-АУДИТ] >>> Запрос раскрытия одноразового токена доступа. ID токена: {token_id}")

    # ИБ-ФИКС: Исправляем NameError, используя полный системный путь класса datetime
    import datetime
    current_time = datetime.datetime.now()
    
    db_conn = None
    db_user = ""
    decrypted_pass = ""

    try:
        # Открываем чистое соединение в локальную СУБД панели по каналу DSN
        db_conn = connect(LOCAL_DB_DSN)
        db_conn.autocommit = True

        with db_conn.cursor() as cursor:
            # Строгий SQL-запрос с обязательной проверкой времени жизни (expires_at)
            cursor.execute(
                "SELECT db_user, encrypted_password FROM one_time_tokens WHERE token_id = %s AND expires_at > %s;",
                (token_id, current_time)
            )
            token_data = cursor.fetchone()

            # АБСОЛЮТНЫЙ ИБ-ПЕРЕХВАТ СГОРЕВШИХ ИЛИ ПОВТОРНЫХ ТОКЕНОВ
            if not token_data:
                # ИБ-ФИКС: Понижаем уровень спама диска до info для защиты от DOS-атак перебором UUID
                logger.info(f"[ИБ-СЕССИЯ] !!! ОТКАЗ В ДОСТУПЕ | Попытка использовать невалидный или просроченный токен: {token_id}")
                return {
                    "status": "error",
                    "message": "Ссылка устарела, сгорела или уже была открыта ранее! (404 Token Expired)"
                }

            # Распаковка выполняется строго после успешной ИБ-проверки на пустоту
            db_user = str(token_data[0])
            decrypted_pass = str(token_data[1])

            # АТОМАРНАЯ САМОЛИКВИДАЦИЯ: Выжигаем секрет из базы данных панели навсегда!
            cursor.execute("DELETE FROM one_time_tokens WHERE token_id = %s;", (token_id,))
            logger.info(f"[ИБ-АУДИТ] -> Токен {token_id} успешно погашен. Секрет удален из СУБД service_manager_db.")

            # ИБ-ЛОГ: Подтверждаем успешный показ учетных данных в логгер сервера
            logger.info(f"[ИБ-АУДИТ] <<< УСПЕХ | Секретные данные для роли '{db_user}' успешно раскрыты пользователю.")
            return {
                "status": "success",
                "username": db_user,
                "password": decrypted_pass,
                "warning": "Внимание! Секрет стерт из базы данных панели навсегда. Запишите его прямо сейчас!"
            }

    except Exception as view_err:
        # КРИТИЧНО ДЛЯ ИБ: Записываем крах дешифрации или СУБД в логгер ОС с подробным traceback
        logger.error(f"[ИБ-КРАХ] Фатальный сбой обработки токена {token_id}: {str(view_err)}", exc_info=True)
        return {
            "status": "error",
            "message": "Критический сбой сервера при верификации секретного токена."
        }

    finally:
        # ГАРАНТИЯ БЕЗОПАСНОСТИ: Закрываем сокет в любом случае, предотвращая утечки пула соединений
        if db_conn and not db_conn.closed:
            db_conn.close()

